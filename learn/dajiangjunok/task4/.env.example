# Aleo deployment environment template.
# Copy this file to .env and fill in real values.

ALEO_NETWORK=testnet
ALEO_ENDPOINT=https://api.explorer.provable.com/v1

# Required: funded Aleo testnet private key.
ALEO_PRIVATE_KEY=APrivateKey...

# Optional: derived from ALEO_PRIVATE_KEY.
ALEO_ADDRESS=aleo1...
ALEO_VIEW_KEY=AViewKey...

# Must match program.json and src/main.leo.
ALEO_PROGRAM_ID=private_token_1lkp6q.aleo
