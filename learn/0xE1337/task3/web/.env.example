# ── Private Gate Pass — web ──────────────────────────────────────────
# No config is required: the app runs end-to-end out of the box.

# DEMO_MODE (default ON) stubs wallet signing with fixtures so the full UI flow
# works with no wallet — used for the demo screenshots. The live public counter
# (gate_access_count) is still read from the real testnet chain.
#
# Set this to false to drive a REAL wallet (Shield / Puzzle / Leo / Fox) and
# submit real transactions instead.
NEXT_PUBLIC_DEMO_MODE=true
