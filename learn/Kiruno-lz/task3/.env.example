# Aleo PII Protocol — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Aleo account private key (for testnet deployment)
# Get testnet credits from: https://faucet.aleo.org/
# Leo 4.x deploy reads PRIVATE_KEY; ALEO_PRIVATEKEY is also accepted as fallback
PRIVATE_KEY=APrivateKey1zkp...

# Optional: override default testnet endpoint
# ENDPOINT=https://api.explorer.provable.com/v1

# Optional: override default network
# NETWORK=testnet
